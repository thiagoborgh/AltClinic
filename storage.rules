rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Regras para mídia do WhatsApp
    match /whatsapp_media/{tenantId}/{fileName} {
      // Permitir leitura autenticada
      allow read: if request.auth != null;
      
      // Permitir escrita apenas para o próprio tenant
      allow write: if request.auth != null 
        && request.auth.token.tenantId == tenantId
        && request.resource.size < 10 * 1024 * 1024 // Máximo 10MB
        && request.resource.contentType.matches('image/.*|video/.*|audio/.*|application/pdf');
    }
    
    // Regras para outros arquivos do sistema
    match /uploads/{tenantId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.token.tenantId == tenantId;
    }
    
    // Bloquear acesso padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
