  "version": "1.0.0",
  "description": "Sistema de Agendamento Automatizado para Clínicas Estéticas",
  "main": "app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node migrations/migrate.js",
    "setup": "node setup.js",
    "health": "node health-check.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "echo 'Build completed - ready for production'",
    "docker:build": "docker build -t saae .",
    "docker:run": "docker run -p 3000:3000 saae",
    "docker:compose": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f saae-app",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "backup:db": "cp ./saee.db ./backup-$(date +%Y%m%d-%H%M%S).db",
    "reset:db": "rm -f ./saee.db && npm run migrate"
  },
