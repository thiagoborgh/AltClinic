rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Tenants - apenas admin pode criar
    match /tenants/{tenantId} {
      allow read: if request.auth != null && 
                     (request.auth.token.tenantId == tenantId || 
                      request.auth.token.role == 'admin');
      allow write: if request.auth != null && request.auth.token.role == 'admin';
      
      // Usuários do tenant
      match /usuarios/{userId} {
        allow read: if request.auth != null && 
                       request.auth.token.tenantId == tenantId;
        allow write: if request.auth != null && 
                        request.auth.token.tenantId == tenantId &&
                        (request.auth.token.role == 'admin' || 
                         request.auth.uid == userId);
      }
      
      // Pacientes do tenant
      match /pacientes/{pacienteId} {
        allow read, write: if request.auth != null && 
                              request.auth.token.tenantId == tenantId;
      }
      
      // Agendamentos do tenant
      match /agendamentos/{agendamentoId} {
        allow read, write: if request.auth != null && 
                              request.auth.token.tenantId == tenantId;
      }
      
      // Médicos do tenant
      match /medicos/{medicoId} {
        allow read, write: if request.auth != null && 
                              request.auth.token.tenantId == tenantId;
      }
    }
    
    // WhatsApp sessions
    match /whatsapp_sessions/{tenantId} {
      allow read, write: if request.auth != null && 
                            request.auth.token.tenantId == tenantId;
    }
    
    // WhatsApp messages
    match /whatsapp_messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Password reset tokens - acesso público para validação
    match /password_reset_tokens/{tokenId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
