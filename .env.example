# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_PATH=./saee.db

# Segurança
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ===========================
# CONFIGURAÇÕES DO SERVIDOR
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# BANCO DE DADOS
# ===========================
DB_PATH=./saee.db

# ===========================
# SEGURANÇA E AUTENTICAÇÃO
# ===========================
# JWT Secret - Use um valor longo e seguro em produção
JWT_SECRET=seu_jwt_secret_super_seguro_de_64_caracteres_ou_mais_aqui_123456

# Chave de criptografia AES - 32 bytes em hex (64 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ===========================
# CONFIGURAÇÕES CRM
# ===========================
# Dias para considerar paciente inativo
DIAS_INATIVO=90

# Dias de proteção contra spam (não enviar mensagens repetidas)
DIAS_SPAM_PROTECTION=30

# ===========================
# INTEGRAÇÃO COM IA (CLAUDE)
# ===========================
# API Key do Claude 3.5 Sonnet (Anthropic)
# Obtenha em: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-seu_token_claude_aqui

# ===========================
# WHATSAPP BUSINESS API (META)
# ===========================
# App ID do Facebook Developers
WA_APP_ID=your_facebook_app_id_here

# System User Access Token (gerado no Business Manager)
WA_SYSTEM_USER_TOKEN=your_system_user_access_token_here

# Webhook Verify Token (token personalizado para validar webhooks)
WA_WEBHOOK_VERIFY_TOKEN=altclinic_webhook_verify_2025

# Phone Number ID (obtido após configurar o número)
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Business Account ID (opcional, para múltiplos números)
WA_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# ===========================
# BOT TELEGRAM
# ===========================
# Token do bot Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJklmNOpqrSTUVwxyz

# ===========================
# MAILCHIMP INTEGRAÇÃO
# ===========================
# API Key do Mailchimp (conta gratuita disponível)
# Obtenha em: Account > Extras > API Keys
MAILCHIMP_API_KEY=sua_api_key_mailchimp_aqui-us1

# Prefixo do servidor (ex: us1, us2, etc - vem no final da API key)
MAILCHIMP_SERVER_PREFIX=us1

# ID da lista de contatos (crie uma lista primeiro)
MAILCHIMP_LIST_ID=seu_list_id_aqui

# ===========================
# CONFIGURAÇÕES DE UPLOAD
# ===========================
# Tamanho máximo de arquivo em bytes (padrão: 5MB)
MAX_FILE_SIZE=5242880

# Pasta para uploads (será criada automaticamente)
UPLOAD_PATH=./uploads

# ===========================
# RATE LIMITING
# ===========================
# Janela de tempo para rate limiting (15 minutos em ms)
RATE_LIMIT_WINDOW_MS=900000

# Máximo de requests por janela de tempo
RATE_LIMIT_MAX_REQUESTS=100

# ===========================
# CONFIGURAÇÕES DE EMAIL SMTP
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua_senha_de_app_do_gmail
EMAIL_FROM=contatoaltclinic@gmail.com
EMAIL_FROM_NAME=AltClinic Sistema

# ===========================
# API EXTERNA DE EMAIL (OPCIONAL)
# ===========================
# Quando definido, a aplicação envia emails via HTTP em vez de SMTP
EMAIL_API_URL=https://seu-relay/email/send
EMAIL_API_KEY=sua-api-key-se-for-necessario

# ===========================
# CONFIGURAÇÕES DOS BOTS
# ===========================
# Delay entre respostas do bot (em ms)
BOT_RESPONSE_DELAY=1000

# Delay para simular digitação (em ms)
BOT_TYPING_DELAY=2000

# ===========================
# CONFIGURAÇÕES DE PRODUÇÃO
# ===========================
# URL base da aplicação
BASE_URL=http://localhost:3000

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3001

# ===========================
# LOGS E MONITORAMENTO
# ===========================
# Nível de log (error, warn, info, debug)
LOG_LEVEL=info

# Ativar logs detalhados
DEBUG_MODE=false

# ===========================
# EXEMPLO DE CONFIGURAÇÃO SEGURA PARA PRODUÇÃO
# ===========================
# Descomente e ajuste para produção:

# NODE_ENV=production
# JWT_SECRET=uma_chave_jwt_super_forte_e_unica_com_pelo_menos_64_caracteres_aleatorios
# ENCRYPTION_KEY=chave_aes_32_bytes_em_hex_gerada_com_crypto_randomBytes_muito_segura
# BASE_URL=https://seu-dominio.com
# FRONTEND_URL=https://app.seu-dominio.com
# DB_PATH=/app/data/saee.db
# UPLOAD_PATH=/app/uploads
# LOG_LEVEL=warn
# DEBUG_MODE=false

# APIs de IA (MVP - Gratuitas)
GEMINI_API_KEY=your_google_gemini_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
AI_PROVIDER=gemini

# WhatsApp via Twilio (Free Tier)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_SESSION_PATH=./whatsapp-session
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_list_id_here

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Timezone
TZ=America/Sao_Paulo

# ===========================
# CONFIGURAÇÃO DE FEATURES (MVP)
# ===========================
# Controla quais funcionalidades estão visíveis no menu
# Valores: true/false

# Funcionalidades principais (sempre recomendadas)
FEATURE_AGENDA=true
FEATURE_PACIENTES=true
FEATURE_PROFISSIONAIS=true
FEATURE_WHATSAPP=true
FEATURE_CONFIGURACOES=true

# Funcionalidades avançadas (ocultas por padrão no MVP)
FEATURE_DASHBOARD=false
FEATURE_FINANCEIRO=false
FEATURE_CRM_AVANCADO=false
FEATURE_RELATORIOS=false
FEATURE_SALA_ESPERA=false
FEATURE_LICENCAS=false

# Funcionalidades experimentais
FEATURE_AUTOMACOES_AVANCADAS=false
FEATURE_INTEGRACOES_EXTERNAS=false
FEATURE_MULTI_CLINICA=false

# ===========================
# ASAAS — GATEWAY DE PAGAMENTO
# ===========================
# Obtenha em: https://www.asaas.com/
# Sandbox automático quando NODE_ENV !== 'production'
ASAAS_API_KEY=your_asaas_api_key_here

# ===========================
# REDIS (UPSTASH) — FILAS BULLMQ
# ===========================
# Crie conta grátis em: https://upstash.com/
# Sem esta variável, jobs rodam via cron simples (sem persistência de fila)
REDIS_URL=rediss://default:your_token@your-host.upstash.io:6379

# ===========================
# SENTRY — MONITORAMENTO DE ERROS
# ===========================
# Crie projeto grátis em: https://sentry.io/
# Sem esta variável, Sentry é desativado silenciosamente
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ===========================
# n8n — AUTOMAÇÃO DE WORKFLOWS
# ===========================
# Usuário e senha para acessar o n8n (http://localhost:5678)
N8N_USER=admin
N8N_PASSWORD=troque_esta_senha_em_producao
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
