# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_PATH=./saee.db

# Segurança
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ===========================
# CONFIGURAÇÕES DO SERVIDOR
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# BANCO DE DADOS
# ===========================
DB_PATH=./saee.db

# ===========================
# SEGURANÇA E AUTENTICAÇÃO
# ===========================
# JWT Secret - Use um valor longo e seguro em produção
JWT_SECRET=seu_jwt_secret_super_seguro_de_64_caracteres_ou_mais_aqui_123456

# Chave de criptografia AES - 32 bytes em hex (64 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ===========================
# CONFIGURAÇÕES CRM
# ===========================
# Dias para considerar paciente inativo
DIAS_INATIVO=90

# Dias de proteção contra spam (não enviar mensagens repetidas)
DIAS_SPAM_PROTECTION=30

# ===========================
# INTEGRAÇÃO COM IA (CLAUDE)
# ===========================
# API Key do Claude 3.5 Sonnet (Anthropic)
# Obtenha em: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-seu_token_claude_aqui

# ===========================
# BOT WHATSAPP
# ===========================
# Caminho para sessão do WhatsApp (será criado automaticamente)
WHATSAPP_SESSION_PATH=./whatsapp-session

# ===========================
# BOT TELEGRAM
# ===========================
# Token do bot Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJklmNOpqrSTUVwxyz

# ===========================
# MAILCHIMP INTEGRAÇÃO
# ===========================
# API Key do Mailchimp (conta gratuita disponível)
# Obtenha em: Account > Extras > API Keys
MAILCHIMP_API_KEY=sua_api_key_mailchimp_aqui-us1

# Prefixo do servidor (ex: us1, us2, etc - vem no final da API key)
MAILCHIMP_SERVER_PREFIX=us1

# ID da lista de contatos (crie uma lista primeiro)
MAILCHIMP_LIST_ID=seu_list_id_aqui

# ===========================
# CONFIGURAÇÕES DE UPLOAD
# ===========================
# Tamanho máximo de arquivo em bytes (padrão: 5MB)
MAX_FILE_SIZE=5242880

# Pasta para uploads (será criada automaticamente)
UPLOAD_PATH=./uploads

# ===========================
# RATE LIMITING
# ===========================
# Janela de tempo para rate limiting (15 minutos em ms)
RATE_LIMIT_WINDOW_MS=900000

# Máximo de requests por janela de tempo
RATE_LIMIT_MAX_REQUESTS=100

# ===========================
# CONFIGURAÇÕES DOS BOTS
# ===========================
# Delay entre respostas do bot (em ms)
BOT_RESPONSE_DELAY=1000

# Delay para simular digitação (em ms)
BOT_TYPING_DELAY=2000

# ===========================
# CONFIGURAÇÕES DE PRODUÇÃO
# ===========================
# URL base da aplicação
BASE_URL=http://localhost:3000

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3001

# ===========================
# LOGS E MONITORAMENTO
# ===========================
# Nível de log (error, warn, info, debug)
LOG_LEVEL=info

# Ativar logs detalhados
DEBUG_MODE=false

# ===========================
# EXEMPLO DE CONFIGURAÇÃO SEGURA PARA PRODUÇÃO
# ===========================
# Descomente e ajuste para produção:

# NODE_ENV=production
# JWT_SECRET=uma_chave_jwt_super_forte_e_unica_com_pelo_menos_64_caracteres_aleatorios
# ENCRYPTION_KEY=chave_aes_32_bytes_em_hex_gerada_com_crypto_randomBytes_muito_segura
# BASE_URL=https://seu-dominio.com
# FRONTEND_URL=https://app.seu-dominio.com
# DB_PATH=/app/data/saee.db
# UPLOAD_PATH=/app/uploads
# LOG_LEVEL=warn
# DEBUG_MODE=false

# APIs de IA (MVP - Gratuitas)
GEMINI_API_KEY=your_google_gemini_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
AI_PROVIDER=gemini

# WhatsApp via Twilio (Free Tier)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_SESSION_PATH=./whatsapp-session
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_list_id_here

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Timezone
TZ=America/Sao_Paulo
