# Porta onde o relay irá rodar
RELAY_PORT=4900

# Chave opcional para proteger o endpoint (enviar no header x-api-key)
RELAY_API_KEY=defina-uma-chave-segura

# Configurações SMTP usadas pelo relay local
RELAY_SMTP_HOST=smtp.gmail.com
RELAY_SMTP_PORT=465
RELAY_SMTP_SECURE=true
RELAY_SMTP_USER=contatoaltclinic@gmail.com
RELAY_SMTP_PASS=senha-ou-app-password
RELAY_SMTP_REJECT_UNAUTHORIZED=false

# Remetente padrão caso não seja enviado na requisição
RELAY_DEFAULT_FROM=AltClinic <contatoaltclinic@gmail.com>
