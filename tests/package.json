{
  "name": "saee-automated-tests",
  "version": "1.0.0",
  "description": "Suite de testes automatizados para SAEE e Intranet Altclinic",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest --testPathPattern=api",
    "test:frontend": "jest --testPathPattern=frontend",
    "test:integration": "jest --testPathPattern=integration",
    "test:admin": "jest --testPathPattern=admin",
    "test:e2e": "playwright test",
    "test:all": "npm run test:api && npm run test:frontend && npm run test:integration && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^6.3.3",
    "sqlite3": "^5.1.6"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/setup.js"],
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "identity-obj-proxy"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "admin/**/*.{js,jsx}",
      "!src/index.js",
      "!admin/frontend/src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
