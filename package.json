{
  "name": "saee-sistema-agendamento",
  "version": "1.0.0",
  "description": "Sistema de Agendamento Automatizado para Clínicas Estéticas",
  "type": "commonjs",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon app.js",
    "build": "cd frontend && npm install && npm run build && cd .. && powershell -ExecutionPolicy Bypass -File copy-build.ps1 && npm install",
    "build:linux": "cd frontend && npm install && npm run build && cd .. && mkdir -p public && cp -r frontend/build/* public/",
    "migrate": "node src/migrate.js run",
    "migrate:create": "node src/migrate.js create",
    "migrate:status": "node src/migrate.js status",
    "setup": "node setup.js",
    "init:production": "node -e \"const init = require('./src/utils/productionInitializer'); init.createFirstAccess().then(() => process.exit(0)).catch(e => {console.error(e); process.exit(1);})\"",
    "seed:tenants": "node scripts/seed-tenants.js",
    "test:apis": "node test-apis.js",
    "health": "node health-check.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "heroku-postbuild": "cd frontend && npm install && npm run build && cd .. && cp -r frontend/build/* public/ && npm install",
    "docker:build": "docker build -t saee .",
    "docker:run": "docker run -p 3000:3000 saee",
    "docker:compose": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f saee-app",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "backup:db": "cp ./saee.db ./backup-$(date +%Y%m%d-%H%M%S).db",
    "reset:db": "rm -f ./saee.db && npm run migrate"
  },
  "keywords": [
    "saas",
    "agendamento",
    "clinica",
    "estetica",
    "crm"
  ],
  "author": "SAEE Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0 <20.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "memory-fs": "^0.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.6",
    "sharp": "^0.34.3",
    "stripe": "^18.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
