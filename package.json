{
  "name": "saee-sistema-agendamento",
  "version": "1.0.0",
  "description": "Sistema de Agendamento Automatizado para Clínicas Estéticas",
  "type": "commonjs",
  "main": "src/app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "migrate": "node src/migrate.js run",
    "migrate:create": "node src/migrate.js create",
    "migrate:status": "node src/migrate.js status",
    "setup": "node setup.js",
    "test:apis": "node test-apis.js",
    "health": "node health-check.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "cd frontend && npm install && npm run build",
    "heroku-postbuild": "cd frontend && npm install && npm run build",
    "docker:build": "docker build -t saee .",
    "docker:run": "docker run -p 3000:3000 saee",
    "docker:compose": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f saee-app",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "backup:db": "cp ./saee.db ./backup-$(date +%Y%m%d-%H%M%S).db",
    "reset:db": "rm -f ./saee.db && npm run migrate"
  },
  "keywords": [
    "saas",
    "agendamento",
    "clinica",
    "estetica",
    "crm"
  ],
  "author": "SAEE Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.7.1",
    "@huggingface/inference": "^2.8.1",
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fabric": "^5.3.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.6",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.7",
    "stripe": "^18.5.0",
    "telegraf": "^4.15.0",
    "twilio": "^4.23.0",
    "uuid": "^11.1.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
