{
  "name": "saee-sistema-agendamento",
  "version": "1.0.0",
  "description": "Sistema de Agendamento Automatizado para Clínicas Estéticas",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:whatsapp": "USE_DEV_PHONE=true node src/app.js",
    "setup:dev": "node setup-development.js setup",
    "setup:reset": "node setup-development.js reset",
    "setup:show": "node setup-development.js show",
    "setup:licenses-central": "node setup-licenses.js setup-central",
    "setup:licenses-propria": "node setup-licenses.js setup-propria",
    "setup:licenses-all": "node setup-licenses.js setup-all",
    "test:dev-whatsapp": "node exemplo-desenvolvimento.js licencas",
    "test:dev-mensagens": "node exemplo-desenvolvimento.js mensagens",
    "build": "cd frontend && npm install && npm run build && cd .. && cd admin/frontend && npm install && npm run build && cd ../.. && powershell -ExecutionPolicy Bypass -File copy-build.ps1 && npm install",
    "build:linux": "cd frontend && npm install && npm run build && cd .. && cd admin/frontend && npm install && npm run build && cd ../.. && mkdir -p public && mkdir -p public/admin && cp -r frontend/build/* public/ && cp -r admin/frontend/build/* public/admin/ && npm install && npm rebuild",
    "postinstall": "npm rebuild better-sqlite3 sharp",
    "migrate": "node src/migrate.js run",
    "migrate:create": "node src/migrate.js create",
    "migrate:status": "node src/migrate.js status",
    "setup": "node setup.js",
    "setup:e2e": "bash setup-e2e-tests.sh || cmd /c setup-e2e-tests.bat",
    "setup:e2e:linux": "bash setup-e2e-tests.sh",
    "setup:e2e:windows": "setup-e2e-tests.bat",
    "init:production": "node -e \"const init = require('./src/utils/productionInitializer'); init.createFirstAccess().then(() => process.exit(0)).catch(e => {console.error(e); process.exit(1);})\"",
    "seed:tenants": "node scripts/seed-tenants.js",
    "test:apis": "node test-apis.js",
    "health": "node health-check.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest --testPathPattern=api",
    "test:frontend": "jest --testPathPattern=frontend",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "cd tests && npm run test:e2e",
    "test:all": "npm run test:api && npm run test:frontend && npm run test:integration && npm run test:e2e",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "heroku-postbuild": "cd frontend && npm install && npm run build && cd .. && cd admin/frontend && npm install && npm run build && cd ../.. && mkdir -p public && mkdir -p public/admin && cp -r frontend/build/* public/ && cp -r admin/frontend/build/* public/admin/ && npm install && npm rebuild",
    "docker:build": "docker build -t saee .",
    "docker:run": "docker run -p 3000:3000 saee",
    "docker:compose": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f saee-app",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "backup:db": "cp ./saee.db ./backup-$(date +%Y%m%d-%H%M%S).db",
    "reset:db": "rm -f ./saee.db && npm run migrate"
  },
  "keywords": [
    "saas",
    "agendamento",
    "clinica",
    "estetica",
    "crm"
  ],
  "author": "SAEE Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.3.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "memory-fs": "^0.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.6",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "stripe": "^18.5.0",
    "uuid": "^11.1.0",
    "whatsapp-web.js": "^1.34.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "jest": "^29.7.0",
    "ngrok": "^5.0.0-beta.2",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
